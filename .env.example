# InvestTrack - Environment Variables Template
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit the .env file to version control!
# ──────────────────────────────────────────────────────────

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # Set a strong database password

# ---- RabbitMQ ----
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=          # Set a strong RabbitMQ password

# ---- JWT ----
# Generate a strong Base64-encoded secret (at least 64 characters):
#   openssl rand -base64 64
JWT_SECRET=                 # REQUIRED - paste your generated secret here
JWT_EXPIRATION_MS=86400000  # 24 hours in milliseconds

# ---- Kite Connect (Market Data) ----
KITE_API_KEY=               # Your Kite Connect API key
KITE_API_SECRET=            # Your Kite Connect API secret

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- pgAdmin ----
PGADMIN_DEFAULT_EMAIL=admin@investtrack.com
PGADMIN_DEFAULT_PASSWORD=   # Set a strong pgAdmin password
